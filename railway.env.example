# Railway environment variables template.
# On Railway: Variables tab → New Variable → paste each KEY=VALUE.
# Or: railway variables set --service <name> KEY=VALUE (CLI)

# ── Required ──────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_free_key_from_console_groq_com

# ── Bot behaviour ─────────────────────────────────────────────
WISH_INTERVAL_MINUTES=5
MEDIA_INTERVAL_MINUTES=60
TZ=Asia/Kolkata

# ── Dashboard auth (strongly recommended — bot is public URL) ──
DASHBOARD_USER=admin
DASHBOARD_PASS=change_me_to_a_long_random_string

# ── Optional ──────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile

# PORT is auto-set by Railway — do NOT define it manually.
# RAILWAY_VOLUME_MOUNT_PATH is auto-set when you attach a volume.
