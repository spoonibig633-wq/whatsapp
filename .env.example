# ── Groq (free tier) ──────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ── Server ────────────────────────────────────────────────────
# Port the dashboard + bot listens on (hosting platform sets PORT automatically)
PORT=3000

# ── Dashboard auth (optional but recommended) ────────────────
# Leave DASHBOARD_USER empty to disable basic auth
DASHBOARD_USER=admin
DASHBOARD_PASS=birthday123

# ── Bot behaviour ─────────────────────────────────────────────
# Groq model to use (free tier-friendly)
GROQ_MODEL=llama-3.3-70b-versatile

# Wish interval in minutes (default 5)
WISH_INTERVAL_MINUTES=5

# Media interval in minutes (default 60)
MEDIA_INTERVAL_MINUTES=60

# Timezone for start/end time window (default Asia/Kolkata)
TZ=Asia/Kolkata
